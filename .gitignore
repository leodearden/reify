.env
.mcp.json
.claude/*
!.claude/skills/
/target
# Rust compiled library artifacts (build output, never source)
*.rlib
**/*.rs.bk
.task/
.taskmaster/
# Bare form (no trailing slash) matches BOTH the directory (normal dev) AND a symlink
# (.worktrees → <mount>/worktrees after relocate-worktrees-to-warm-lane.sh).
# A trailing-slash pattern is directory-only and would NOT match the post-relocation
# symlink, leaving it as an untracked file (?? .worktrees) and breaking the
# land.sh clean-tree gate. (task 4696 / DA2 path-stable symlink)
.worktrees
.eval-worktrees/
data/escalations/
node_modules/
# Also ignore as a bare path (no trailing slash) because git tracks symlinks as mode-120000
# blobs, not directories — the trailing-slash rule above does not match symlinks. This
# explicit entry prevents a worktree-local gui/node_modules symlink from being re-added.
gui/node_modules
gui/sidecar/node_modules
/package.json
/package-lock.json
gui/package-lock.json
# legacy pnpm lockfile — project uses npm (see packageManager in package.json)
gui/pnpm-lock.yaml
gui/sidecar/package-lock.json
tree-sitter-reify/package-lock.json
# stray root lock file leaked by a test/tool into CWD — never a source artifact
/.lock
test_bracket.reify
.orchestrator/reconciliation/*.db*
.orchestrator/queue/*.db*
data/.orchestrator/queue/*.db*
*.kate-swp
.jcodemunch.jsonc
data/review-checkpoints/
data/orchestrator/
data/audit-runs/
gui/src-tauri/gen/
orchestrator.log*
review/reports/

# Tree-sitter generated (regenerate via scripts/tree-sitter-generate.sh)
tree-sitter-reify/src/parser.c
tree-sitter-reify/src/grammar.json
tree-sitter-reify/src/node-types.json
tree-sitter-reify/src/.grammar_hash.stamp
tree-sitter-reify/src/.generate.lock
tree-sitter-reify/src/.generate.lock.d

# Sidecar build artifacts
gui/dist/
gui/sidecar/dist/
gui/src-tauri/sidecar/reify-sidecar-*

# Python bytecode (CPython __pycache__ directories and .pyc files)
__pycache__/
*.pyc
