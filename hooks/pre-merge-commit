#!/usr/bin/env bash
# Pre-merge-commit hook: gate `git merge` (including --no-ff) into main.
#
# pre-commit fires for ordinary commits but NOT for the merge commit created by
# a clean `git merge` — so without this hook, a --no-ff merge into main bypasses
# the verification gate entirely. This closes that gap. Auto-active via
# core.hooksPath=hooks; bypass with `git merge --no-verify`.
#
# A merge cannot trust `git diff --cached` (the index is the merge result, not a
# curated stage), so we verify the full workspace (--scope all). verify.sh also
# detects MERGE_HEAD and forces --scope all defensively. Worktree branches skip
# the gate for speed, matching hooks/pre-commit (the orchestrator's task-branch
# merges are not main and are gated by the orchestrator's own verify).
#
# --profile both (NOT debug): the merge gate is where release coverage lives.
# Per-task verify (orchestrator.yaml) and the per-commit gate (hooks/project-
# checks) both run --profile debug for fast feedback; release reruns far less
# often, so it is pinned here, at the merge boundary. This is also where the
# heavy release-only tests in reify-solver-elastic — gated behind
# #[cfg_attr(debug_assertions, ignore)] (buckling/eigensolve) — actually run:
# release sets debug_assertions=false, so the ignore lifts and they execute
# exactly once, at merge, instead of imposing their multi-minute floor on every
# per-task iteration.

ROOT="$(git rev-parse --show-toplevel)"

branch="$(git rev-parse --abbrev-ref HEAD)"
if [ "$branch" != "main" ]; then
    exit 0
fi

exec "$ROOT/scripts/verify.sh" all --profile both --scope all
