#!/usr/bin/env bash
# reify project-specific checks (called from hooks/pre-commit, main branch only).
#
# Thin delegation to scripts/verify.sh — the single source of truth shared with
# orchestrator.yaml. --scope staged scopes the gate by `git diff --cached`, so a
# docs-only or empty stage produces an empty plan and exits 0 (the previous
# "no source changes — skipping" fast path is now subsumed by the scope picker).
# --profile debug keeps the per-commit gate fast (release coverage is the
# orchestrator's job — the one deliberate hook↔orchestrator divergence).
# verify.sh bakes in the cargo env, sccache/jobserver, and OCCT LD_LIBRARY_PATH,
# so the hook no longer depends on the caller's ambient environment.
#
# Receives repo root as $1.

ROOT="${1:?}"

exec "$ROOT/scripts/verify.sh" all --profile debug --scope staged --include-infra
