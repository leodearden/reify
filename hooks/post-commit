#!/usr/bin/env bash
# Post-commit hook: normalize .taskmaster/tasks/tasks.json task and subtask IDs
# from JSON integers to digit-strings after any commit that touches that file.
#
# The Taskmaster CLI (Node.js) serialises new IDs as integers.  This hook
# detects such commits and amends them with the corrected file so the
# regression test test_tasks_json_id_types.sh stays GREEN.
#
# Recursion guard: the amend itself triggers another post-commit invocation.
# We break the loop with an environment variable that is set only for the
# amend subprocess and is invisible to parent or sibling processes.

set -eu

# (1) Recursion guard — must be the first executable line after set.
if [ "${_REIFY_TASKS_NORMALIZE_AMEND:-}" != "" ]; then
    exit 0
fi

# (2) Repo root.
ROOT="$(git rev-parse --show-toplevel)"

# (3) Nothing to do if the file doesn't exist on disk.
TASKS_JSON="$ROOT/.taskmaster/tasks/tasks.json"
if [ ! -f "$TASKS_JSON" ]; then
    exit 0
fi

# (4) Exit early if this commit didn't touch tasks.json.
# --root is required so that root (first) commits are compared against the
# empty tree rather than producing no output (which would cause a false exit).
if ! git diff-tree --root -r --no-commit-id --name-only HEAD | grep -qF '.taskmaster/tasks/tasks.json'; then
    exit 0
fi

# (5) Run the normalizer.  On script error, do NOT block the commit — just exit.
python3 "$ROOT/scripts/normalize_tasks_json.py" "$TASKS_JSON" || exit 0

# (6) If the file changed on disk vs HEAD, stage it and amend.
if ! git diff --quiet -- "$TASKS_JSON"; then
    git add -- "$TASKS_JSON"
    _REIFY_TASKS_NORMALIZE_AMEND=1 git commit --amend --no-edit --no-verify -q
fi
