#!/usr/bin/env bash
# Post-commit hook: normalize .taskmaster/tasks/tasks.json task and subtask IDs
# from JSON integers to digit-strings after any commit that touches that file.
#
# The Taskmaster CLI (Node.js) serialises new IDs as integers.  This hook
# detects such commits and amends them with the corrected file so the
# regression test test_tasks_json_id_types.sh stays GREEN.
#
# Recursion guard: the amend itself triggers another post-commit invocation.
# We break the loop with an environment variable that is set only for the
# amend subprocess and is invisible to parent or sibling processes.

set -eu

# (1) Recursion guard — must be the first executable line after set.
if [ "${_REIFY_TASKS_NORMALIZE_AMEND:-}" != "" ]; then
    exit 0
fi

# Helper: emit a loud ANSI-red ERROR: banner, write a persistent marker file
# under $GIT_DIR, and exit non-zero.  Used for both python3-missing and
# normalizer-crash paths so failures are surfaced to the developer whether
# they are watching the terminal or checking .git state later.
#
# Usage: _loud_fail <human-readable message> <short-reason-tag>
_loud_fail() {
    local _msg="$1" _reason="$2"
    printf '\033[1;31mERROR:\033[0m %s\n' "$_msg" >&2
    local _git_dir
    _git_dir="$(git rev-parse --git-dir 2>/dev/null || printf '.git')"
    printf '%s\t%s\t%s\n' \
        "$(date -Is 2>/dev/null || date -u +%Y-%m-%dT%H:%M:%SZ)" \
        "$_reason" \
        "$(git rev-parse HEAD 2>/dev/null || printf 'unknown')" \
        > "$_git_dir/NORMALIZE_FAILED"
    exit 1
}

# (2) Repo root.
ROOT="$(git rev-parse --show-toplevel)"

# (3) Nothing to do if the file doesn't exist on disk.
TASKS_JSON="$ROOT/.taskmaster/tasks/tasks.json"
if [ ! -f "$TASKS_JSON" ]; then
    exit 0
fi

# (3.5) Optional: surface known_gap closures when a done-task auto-commit fires.
#
# Placed BEFORE step (4) so it fires on any commit whose message matches the
# done-task pattern, including --allow-empty commits.  In real usage the
# set_task_status auto-commit always touches tasks.json, but the check should
# be independent of that: it reads tasks.json from disk (guaranteed to exist
# after step 3) and the commit-message regex is the sole gate.
#
# Gate conditions:
#   (a) Commit message matches set_task_status(NNN=done) — avoids spurious work
#       on in-progress/pending transitions and plain source commits.
#       Regex `set_task_status\([0-9]+=done\)` is strict: requires the literal
#       token "=done)" so "=in-progress" or "=pending" commits are excluded.
#       Tests/infra/test_post_commit_hook.sh Checks 10-11 verify this boundary.
#   (b) Both review/briefing.yaml and scripts/refresh_briefing_known_gaps.py
#       exist in the worktree — silently no-ops if either is absent.
#
# STRICTLY INFORMATIONAL: never calls _loud_fail, never exits non-zero.
# NOTE: no stdout/stderr redirection — the script's WARN lines go straight to
# the hook's stderr (the developer's terminal), which is the intended UX.
_commit_msg="$(git log -1 --format=%s 2>/dev/null || true)"
if command -v python3 >/dev/null 2>&1 \
    && echo "$_commit_msg" | grep -qE 'set_task_status\([0-9]+=done\)' \
    && [ -f "$ROOT/review/briefing.yaml" ] \
    && [ -f "$ROOT/scripts/refresh_briefing_known_gaps.py" ]; then
    python3 "$ROOT/scripts/refresh_briefing_known_gaps.py" \
        --briefing "$ROOT/review/briefing.yaml" \
        --tasks "$TASKS_JSON" \
        --quiet || true
fi

# (4) Exit early if this commit didn't touch tasks.json.
# --root is required so that root (first) commits are compared against the
# empty tree rather than producing no output (which would cause a false exit).
# -m is required so that merge commits are diffed against each parent; without
# it, git diff-tree emits no output for merges and normalization would be
# silently skipped on a merge that introduces numeric IDs.
if ! git diff-tree -m --root -r --no-commit-id --name-only HEAD | grep -qFx '.taskmaster/tasks/tasks.json'; then
    exit 0
fi

# (5) Run the normalizer.  Detect python3-missing and normalizer-crash as loud
# failures: ANSI-red banner on stderr, persistent .git/NORMALIZE_FAILED marker,
# non-zero exit.  git ignores non-zero post-commit exit codes, but the banner
# remains visible in the terminal and the marker persists for automation.
command -v python3 >/dev/null 2>&1 || {
    _loud_fail "python3 not found on PATH — tasks.json ID normalization skipped" \
               "python3-missing"
}
python3 "$ROOT/scripts/normalize_tasks_json.py" "$TASKS_JSON" || {
    _loud_fail "normalize_tasks_json.py exited non-zero — tasks.json NOT normalized" \
               "normalizer-crash"
}

# (6) If the file changed on disk vs HEAD, stage it and amend.
# --no-verify skips pre-commit/commit-msg hooks on the amend.  This applies
# to ALL tasks.json-touching commits, not only auto-commits from the Taskmaster
# pipeline — a manual edit that happens to touch tasks.json will also have its
# pre-commit hooks bypassed on the amend.  This is intentional: the only change
# introduced by the amend is int→str ID normalization, which cannot violate any
# structural invariant checked by pre-commit.
if ! git diff --quiet -- "$TASKS_JSON"; then
    git add -- "$TASKS_JSON"
    _REIFY_TASKS_NORMALIZE_AMEND=1 git commit --amend --no-edit --no-verify -q
fi

# (7) Clear any stale failure marker so it reflects only the *last* attempt.
# An absent marker means "last attempt succeeded end-to-end" (normalize AND
# amend); a present marker means "last attempt failed".  This runs after
# step (6) so that an amend failure (index lock, signing error under set -eu)
# leaves the marker in place rather than clearing it prematurely.
rm -f "$(git rev-parse --git-dir 2>/dev/null || printf '.git')/NORMALIZE_FAILED"
