# Skip lifecycle scripts (preinstall/install/postinstall) during `npm ci`.
#
# Rationale: tree-sitter-cli's `install` script downloads a prebuilt binary
# from GitHub releases (https://github.com/tree-sitter/tree-sitter/releases).
# When that download is flaky or unavailable, `npm ci` fails — which then
# bubbles up as a spurious post-merge verification failure in the orchestrator
# even for tasks that never touched tree-sitter or JS/TS.
#
# Nothing in this repo consumes node_modules/.bin/tree-sitter:
#   - build.rs invokes `tree-sitter` from $PATH (system install)
#   - scripts/tree-sitter-generate.sh invokes `tree-sitter` from $PATH
#   - No shell script, Rust crate, or JS file references node_modules here
# The only purpose of `npm ci` in this directory is lockfile integrity
# verification, which still runs with ignore-scripts.
ignore-scripts=true
