{
  "name": "@reify/sidecar",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.9.7",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --noExternal @reify/shared-utils",
    "build:sidecar": "bash build-sidecar.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-code": "^2.1.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@reify/shared-utils": "file:../packages/shared-utils"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
