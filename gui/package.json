{
  "name": "@reify/gui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:grammar": "lezer-generator src/editor/reify.grammar -o src/editor/reifyParser.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:grammar",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "wdio run wdio.conf.ts",
    "e2e:smoke": "wdio run wdio.conf.ts --spec e2e/smoke.e2e.ts",
    "e2e:bracket": "REIFY_E2E_FILE=examples/bracket.ri wdio run wdio.conf.ts --spec e2e/bracket-load.e2e.ts",
    "e2e:visual": "REIFY_E2E_FILE=examples/bracket.ri wdio run wdio.conf.ts --spec e2e/visual-regression.e2e.ts"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.26.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/lr": "^1.4.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "solid-js": "^1.9.0",
    "three": "^0.183.2"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.0",
    "@solidjs/testing-library": "^0.8.0",
    "@types/three": "^0.183.1",
    "@wdio/cli": "^9.26.1",
    "@wdio/local-runner": "^9.26.1",
    "@wdio/mocha-framework": "^9.26.1",
    "@wdio/spec-reporter": "^9.26.1",
    "jsdom": "^25.0.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0",
    "webdriverio": "^9.26.1"
  }
}
