{
  "name": "@reify/gui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "npm@10.9.7",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build:grammar": "lezer-generator src/editor/reify.grammar -o src/editor/reifyParser.js",
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build:grammar",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "tsx test/visual/run.ts",
    "test:e2e": "tsx test/visual/run.ts value",
    "test:smoke:find-uses": "bash test/visual/run_find_uses_smoke.sh",
    "test:smoke:diagnostics": "bash test/visual/run_diagnostics_e2e_smoke.sh"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.0",
    "@codemirror/commands": "^6.3.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/lint": "^6.8.0",
    "@codemirror/search": "^6.6.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.26.0",
    "@lezer/highlight": "^1.2.0",
    "@lezer/lr": "^1.4.0",
    "@reify/shared-utils": "^0.1.0",
    "@tauri-apps/api": "^2.0.0",
    "@tauri-apps/plugin-dialog": "^2.2.0",
    "html-to-image": "^1.11.11",
    "solid-js": "^1.9.0",
    "three": "^0.183.2",
    "three-mesh-bvh": "^0.9.9"
  },
  "devDependencies": {
    "@lezer/generator": "^1.7.0",
    "@solidjs/testing-library": "^0.8.0",
    "@types/node": "^25.6.0",
    "@types/pngjs": "^6.0.5",
    "@types/three": "^0.183.1",
    "jsdom": "^25.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "postcss": "^8.5.14",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^3.0.0"
  }
}
