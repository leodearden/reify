{
  "productName": "Reify",
  "version": "0.1.0",
  "identifier": "dev.reify.app",
  "build": {
    "beforeDevCommand": "npm run dev -- --port 1420",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "features": ["gui"]
  },
  "app": {
    "windows": [
      {
        "title": "Reify",
        "width": 1400,
        "height": 900,
        "resizable": true
      }
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "dmg", "msi", "nsis"],
    "externalBin": ["sidecar/reify-sidecar"],
    "resources": ["sandbox/landlock.py", "sandbox/landlock_exec.py"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "shortDescription": "Parametric CAD with constraint-based modeling",
    "longDescription": "Reify is a declarative parametric CAD tool that uses constraint-based modeling with a custom language (.ri files) for defining geometry, parameters, and constraints.",
    "fileAssociations": [
      {
        "ext": ["ri"],
        "mimeType": "text/x-reify",
        "description": "Reify design file"
      }
    ],
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "libgtk-3-0"]
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256"
    }
  }
}
