// Stdlib: Manufacturing-stock collections (std.stock).
// Provides standard bolt length and sheet thickness series referenced by
// @solver_hint annotations (e.g. @solver_hint("discrete_set", standard_bolt_lengths)).
//
// Representation note: these series are conceptually constant reference data,
// but Reify currently has no top-level `const` declaration syntax (the
// `Declaration` enum in `crates/reify-syntax/src/lib.rs` admits only
// Structure/Occurrence/Import/Enum/Function/Trait/Field/Purpose/Constraint/
// Unit/TypeAlias). They are exposed as zero-arg `pub fn` so the
// `@solver_hint("discrete_set", standard_bolt_lengths)` and
// `@solver_hint("prefer_stock", standard_sheet_thicknesses)` references
// can resolve through the existing function-resolution path. When/if
// language-level `pub const` is added, these should be migrated — at which
// point the call-site evaluation path narrows from
// eval_user_function_call (let_bindings + fresh scope + result_expr) to a
// constant lookup, eliminating the per-call `Value::List` allocation noted
// in task #2455.

/// Standard ISO 4014 / ISO 4017 bolt length series, 8 mm through 100 mm.
/// Values are the canonical preferred increments used in fastener catalogues.
/// Intended to be referenced as the second arg of `@solver_hint("discrete_set", standard_bolt_lengths)`.
pub fn standard_bolt_lengths() -> List<Length> {
    [8mm, 10mm, 12mm, 14mm, 16mm, 20mm, 25mm, 30mm, 35mm, 40mm,
     45mm, 50mm, 55mm, 60mm, 65mm, 70mm, 75mm, 80mm, 90mm, 100mm]
}

/// Common metal sheet stock thicknesses, 0.5 mm through 10 mm.
/// Covers the typical gauges used in cold-rolled steel and aluminum sheet stock.
/// Intended to be referenced as the second arg of `@solver_hint("prefer_stock", standard_sheet_thicknesses)`.
pub fn standard_sheet_thicknesses() -> List<Length> {
    [0.5mm, 0.8mm, 1.0mm, 1.2mm, 1.5mm, 2.0mm, 2.5mm, 3.0mm,
     4.0mm, 5.0mm, 6.0mm, 8.0mm, 10.0mm]
}
