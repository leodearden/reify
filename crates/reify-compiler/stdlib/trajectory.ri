// Stdlib: Trajectory Input Shaping  (`std.trajectory`)
//
// PRD: docs/prds/v0_3/trajectory-input-shaping.md §4.1, §11 task α.
//
// Provides the named-type substrate for the v0.3 trajectory-input-shaping
// PRD — every consumer task (β / δ / η / ι / ξ) depends on the trait, enum,
// and structure_def names declared here. Scope is the type surface only —
// no Rust evaluator and no constructor side effects (that is β).
//
// Surface (PRD §4.1, §5, §5.2):
//   - trait Profile                     (marker for all motion-profile variants)
//   - trait BoundaryCondition           (marker for all spline boundary kinds)
//   - enum  SplineKind                  (CubicSpline | QuinticSpline)
//   - structure def Waypoint            (t, values, vels?, accels?)
//   - structure def NaturalSpline       (zero-DOF marker : BoundaryCondition)
//   - structure def ClampedSpline       (start_velocity, end_velocity : BoundaryCondition)
//   - structure def PeriodicSpline      (zero-DOF marker : BoundaryCondition)
//   - structure def PiecewisePolynomialProfile : Profile
//                                       (mechanism, waypoints, boundary, spline_kind;
//                                        constraint waypoints.count > 0)
//   - trait Shaper                      (marker for all input-shaper variants, PRD §5)
//   - structure def JointLimit          (per-joint actuator constraint, PRD §5.2)
//   - structure def TOTSShaper : Shaper  (time-optimal trajectory shaper, PRD §5.2)
//
// Module placement: registered last in `stdlib_loader.rs` — `std.trajectory`
// has no compile-time dependency on any other stdlib module (every type it
// references is a primitive, builtin parametric container, the `Time`
// dimension from `std.units`, or a name declared in this file). The trailing
// position keeps the v0.3 trajectory cluster visually grouped at the end of
// the loader, ready for the planned `std.modal` / `std.dynamics` siblings.
//
// Encoding notes:
//   1. `JointValue` is declared as a `pub type JointValue = Real` alias at
//      the top of the file so call sites read `List<JointValue>` exactly
//      matching the PRD §4.1 declaration. The kinematic-constraints
//      completion PRD (sibling, not yet landed) will replace the underlying
//      `Real` with a proper kinematic-scalar type; that single alias line
//      retargets every consumer in this file without touching any
//      structure_def body. Same posture as `analysis.ri::pub type Stress =
//      Pressure` and `pub type Strain = Dimensionless`.
//   2. `mechanism` on `PiecewisePolynomialProfile` uses bare `Real` with a
//      `TODO(mechanism-type)` note pointing at the same sibling PRD. No
//      analogous alias makes sense (Mechanism is a structural type, not a
//      scalar dimension) — same pattern as `LoadCase.loads : List<Real>`'s
//      `TODO(load-trait)` annotation in `fea_multi_case.ri`.

// ── Type aliases ──────────────────────────────────────────────────────────

// JointValue: per-joint scalar — position / velocity / acceleration depending
// on the call-site. Currently aliased to `Real` as the kinematic-completion
// PRD (which owns the proper kinematic-scalar type) has not landed yet.
// Same placeholder convention as `fea_multi_case.ri::LoadCase.loads :
// List<Real>` with its `TODO(load-trait)` annotation. Retargeting this line
// when the kinematic PRD lands propagates the type tightening to every
// consumer in this file without touching any structure_def body.
//
// TODO(joint-value-type): retarget to the kinematic-completion PRD's
// `JointValue` (likely `Scalar<...>` or a struct) when that PRD lands.
pub type JointValue = Real

// ── Marker traits ─────────────────────────────────────────────────────────

// Profile — marker trait for every motion-profile variant (PRD §4.1).
// Currently only `PiecewisePolynomialProfile` refines it; future variants
// (TrapezoidalProfile, SCurveProfile, …) are queued in later v0.3 phases.
//
// Kept empty by design: every shared member would force every variant to
// carry redundant data and defeat the marker-trait purpose. Future shared
// fields (e.g. `total_duration`) land in their own phases once the design
// has settled on a single representation.
trait Profile { }

// BoundaryCondition — marker trait for every spline boundary-mode variant
// (PRD §4.1). The α phase declares three refining structures:
//   - NaturalSpline   ("zero second derivative at endpoints")
//   - ClampedSpline   ("specified tangents at first / last waypoint")
//   - PeriodicSpline  ("first and last waypoint agree")
//
// Kept empty: each variant encodes its semantic invariant in the β-phase
// evaluator (`PiecewisePolynomialProfile` coefficient construction), not as
// an authoring-time param. The trait exists only to give the `boundary`
// param on `PiecewisePolynomialProfile` a single nominal type so the
// evaluator dispatches on the concrete variant via the SIR-α nominal
// type-tag — exactly the same mechanism `solve_elastic_static` uses to
// dispatch on `PointLoad` vs `FixedSupport`.
trait BoundaryCondition { }

// ── Spline degree selector ────────────────────────────────────────────────

// SplineKind — selects the polynomial degree the β evaluator uses when
// building the per-segment coefficients for a `PiecewisePolynomialProfile`
// (PRD §4.1):
//
//   CubicSpline   — degree-3 polynomial per segment; the default when
//                   waypoints carry only positions (vels / accels are none).
//   QuinticSpline — degree-5 polynomial per segment; selected when waypoints
//                   carry explicit `vels` AND `accels` (per-waypoint q̇ and q̈
//                   give the extra degrees of freedom a quintic needs).
//
// Same module-top-level positioning as `enum HardnessScale` in
// `materials_mechanical.ri`.
enum SplineKind { CubicSpline, QuinticSpline }

// ── Waypoint ──────────────────────────────────────────────────────────────

// Waypoint — per-knot data the spline interpolates between (PRD §4.1).
//
//   t       : Time                          — knot time
//   values  : List<JointValue>              — per-joint positions
//   vels    : Option<List<JointValue>>      — optional per-joint q̇
//   accels  : Option<List<JointValue>>      — optional per-joint q̈
//
// No defaults — every field is caller-supplied (the spline path through the
// waypoints is entirely determined by the caller's data). `vels` / `accels`
// are `Option`-typed so the caller can omit per-knot derivative data when
// the chosen `SplineKind` does not need it (cubic interpolation works with
// positions alone; quintic needs both).
//
// No structure-level constraint: the only meaningful cross-field invariant
// (`vels.len() == values.len()` when present) is owned by the β-phase
// profile builder once it sees all waypoints together — a per-knot constraint
// cannot see the rest of the waypoint list, so the check belongs there.
//
// TODO(joint-value-type): `List<JointValue>` retargets to the kinematic-
// completion PRD's proper `JointValue` type when that PRD lands (see the
// header §1 type alias note).
structure def Waypoint {
    param t : Time
    param values : List<JointValue>
    param vels : Option<List<JointValue>>
    param accels : Option<List<JointValue>>
}

// ── BoundaryCondition variants ────────────────────────────────────────────

// NaturalSpline — zero-DOF "natural" boundary marker (PRD §4.1).
// Semantic invariant: "zero second derivative at the endpoints" — enforced
// by the β-phase evaluator when it builds the spline coefficients, NOT as
// an authoring-time param. The structure exists only to give the β
// evaluator a nominal type-tag to dispatch on; the dispatch shape mirrors
// `PointLoad` / `FixedSupport` in `solve_elastic_static`.
structure def NaturalSpline : BoundaryCondition { }

// ClampedSpline — "clamped" boundary marker carrying explicit per-joint
// velocity tangents at the first and last waypoint (PRD §4.1):
//
//   start_velocity : List<JointValue>   — q̇ at the first waypoint
//   end_velocity   : List<JointValue>   — q̇ at the last waypoint
//
// Both lists are caller-supplied (no defaults): a "clamped" boundary is
// only meaningful when the caller has a specific tangent intent. The β-
// phase evaluator dispatches on the SIR-α nominal type-tag — exactly the
// same mechanism `solve_elastic_static` uses to dispatch on `PointLoad`
// vs `FixedSupport`.
//
// No structure-level constraint: the only meaningful cross-list invariant
// (`start_velocity.len() == end_velocity.len() == waypoints[0].values.len()`)
// is profile-level and owned by the β-phase profile builder once it sees
// the waypoints together — a per-clamped-spline constraint cannot see the
// rest of the profile, so the check belongs there.
//
// TODO(joint-value-type): `List<JointValue>` retargets to the kinematic-
// completion PRD's proper `JointValue` type when that PRD lands (see the
// header §1 type alias note).
structure def ClampedSpline : BoundaryCondition {
    param start_velocity : List<JointValue>
    param end_velocity : List<JointValue>
}

// PeriodicSpline — zero-DOF "periodic" boundary marker (PRD §4.1).
// Semantic invariant: "the first and last waypoint agree" (both position
// and derivatives), so the resulting spline closes back on itself —
// enforced by the β-phase evaluator when it builds the spline coefficients,
// NOT as an authoring-time param. The structure exists only to give the β
// evaluator a nominal type-tag to dispatch on; the dispatch shape mirrors
// `PointLoad` / `FixedSupport` in `solve_elastic_static`.
structure def PeriodicSpline : BoundaryCondition { }

// ── PiecewisePolynomialProfile ────────────────────────────────────────────

// PiecewisePolynomialProfile — α-phase concrete `Profile` variant carrying
// the four authoring-time params the β-phase evaluator needs to build
// per-segment polynomial coefficients (PRD §4.1):
//
//   mechanism   : Real                 — the kinematic chain whose joints
//                                        the profile interpolates over.
//                                        Currently `Real` placeholder.
//   waypoints   : List<Waypoint>       — per-knot data, ordered by `t`.
//   boundary    : BoundaryCondition    — variant chooses tangent / endpoint
//                                        policy (Natural / Clamped /
//                                        Periodic). The β evaluator
//                                        dispatches on the SIR-α nominal
//                                        type-tag exactly as
//                                        `solve_elastic_static` does for
//                                        `PointLoad` vs `FixedSupport`.
//   spline_kind : SplineKind           — selects polynomial degree (cubic
//                                        for position-only waypoints,
//                                        quintic when waypoints carry
//                                        vels AND accels).
//
// No defaults — every field is caller-supplied. There is no meaningful
// default `mechanism` (the chain is the whole point of a motion profile),
// no default `waypoints` (an empty profile is rejected by the constraint
// below — see step-20), no default `boundary` (the caller must choose
// `NaturalSpline` / `ClampedSpline` / `PeriodicSpline` explicitly), and no
// default `spline_kind` (the cubic-vs-quintic decision is the caller's per-
// problem trade-off).
//
// TODO(mechanism-type): tighten `mechanism : Real` to the kinematic-
// completion PRD's `Mechanism` type when that PRD lands. Same shape and
// rationale as `LoadCase.loads : List<Real>` with its `TODO(load-trait)`
// annotation in `fea_multi_case.ri:84`.
structure def PiecewisePolynomialProfile : Profile {
    param mechanism : Real
    param waypoints : List<Waypoint>
    param boundary : BoundaryCondition
    param spline_kind : SplineKind

    // Reject an empty waypoint list at construction.
    //
    // Encodes the PRD §11-α observable signal "ctor constraints fire
    // (e.g. empty waypoints list rejected)" as an explicit contract in
    // production code rather than relying solely on test coverage (task
    // 2544 convention; same shape `BucklingOptions.n_modes > 0` uses in
    // `solver_buckling.ri`). The `.count` method on `List` is recognised
    // in constraint position (`reify-expr/src/lib.rs:1349` evaluator arm;
    // precedent: `constraint vents.count == n` in
    // `forall_statement_lower_tests.rs`).
    //
    // Fires automatically at construction via SIR-α's
    // `check_constraints_against_templates` machinery (task 3540, landed)
    // — no further plumbing needed in this task.
    constraint waypoints.count > 0
}

// ── Evaluator helper fn signatures (compiler-known intrinsics) ────────────────
//
// These four functions are declared with minimal type-correct stub bodies that
// satisfy the grammar's `fn_body` requirement. The stubs document the signature
// surface so consumer tasks (β, γ, δ, ε, η, ι, ξ) can type-check their call
// sites at α time.
//
// Design decision: stub bodies are used rather than body-less intrinsic
// declarations because the Reify grammar requires `fn_body` for every `fn`
// declaration (`tree-sitter-reify/grammar.js:91-96`; `reify-syntax/src/lib.rs:
// 567-579`). The body-less form `fn f(...) -> T;` does not parse. Extending the
// grammar for body-less intrinsic declarations is beyond α scope (touches
// grammar + parser + lowering for all stdlib modules). The β task (3816) will
// replace the stub bodies — either by editing them to call into the real
// B-spline evaluator once `reify-stdlib/src/trajectory/spline.rs` lands, or by
// switching dispatch to the runtime-intrinsic registry scaffolded on
// `preserved/trajectory-beta-spline` (`crates/reify-stdlib/src/trajectory/
// mod.rs::eval_trajectory` — commit e075cff59a recognises all four names).
//
// Stub body conventions:
//   - `List<JointValue>` returns → `[0.0]`  (single-element Real list; avoids
//     the "cannot infer element type of empty list literal" warning at
//     `reify-compiler/src/expr.rs:2082`)
//   - `Time` return → `0.0 * 1s`  (numeric × unit-literal; pattern from
//     `units.ri:82` `STANDARD_GRAVITY = 9.80665 * 1m / (1s * 1s)`)
//
// α-phase hazard: if a call to any of these fns reaches the evaluator before
// β-3816 lands, it will silently return the stub value (`[0.0]` or `0.0 * 1s`)
// rather than a real result. No α-phase consumer is expected to invoke these
// fns at runtime; the risk is low. β-3816 closes the hazard by replacing each
// stub body with the real evaluator dispatch.

// evaluate_profile — sample a Profile at time `t`, returning the per-joint
// position vector q(t) (PRD §4.1 line 241).
//
// `p : Profile` accepts any concrete Profile variant via the nominal type-tag
// mechanism (`PiecewisePolynomialProfile : Profile`). `t : Time` is the
// evaluation instant within the profile's `[0, T]` domain.
//
// TODO(beta-3816): replace stub body `[0.0]` with the real B-spline evaluator
// (de Boor recursion) once `reify-stdlib/src/trajectory/spline.rs` lands.
pub fn evaluate_profile(p: Profile, t: Time) -> List<JointValue> { [0.0] }

// evaluate_profile_dot — first-derivative companion to `evaluate_profile`.
// Returns the per-joint velocity vector q̇(t) at time `t` (PRD §4.1 line 242).
//
// TODO(beta-3816): replace stub body `[0.0]` with B-spline first-derivative
// evaluation once `reify-stdlib/src/trajectory/spline.rs` lands.
pub fn evaluate_profile_dot(p: Profile, t: Time) -> List<JointValue> { [0.0] }

// evaluate_profile_ddot — second-derivative companion to `evaluate_profile`.
// Returns the per-joint acceleration vector q̈(t) at time `t`
// (PRD §4.1 line 243).
//
// TODO(beta-3816): replace stub body `[0.0]` with B-spline second-derivative
// evaluation once `reify-stdlib/src/trajectory/spline.rs` lands.
pub fn evaluate_profile_ddot(p: Profile, t: Time) -> List<JointValue> { [0.0] }

// profile_duration — duration accessor returning the profile's total `[0, T]`
// span as a Time-dimensioned scalar (PRD §4.1 line 244).
//
// Takes only `p : Profile` (no `t` param — duration is a property of the
// profile itself, not a function of the evaluation instant). The stub body
// `0.0 * 1s` is the numeric-times-unit-literal pattern from `units.ri:82`
// (`STANDARD_GRAVITY = 9.80665 * 1m / (1s * 1s)`).
//
// TODO(beta-3816): replace stub body `0.0 * 1s` with the actual duration
// computation (`waypoints.last.t - waypoints.first.t`) once the B-spline
// evaluator and the PiecewisePolynomialProfile runtime accessor land.
pub fn profile_duration(p: Profile) -> Time { 0.0 * 1s }

// ── Shaper marker trait (PRD §5) ──────────────────────────────────────────────

// Shaper — marker trait for every input-shaper variant (PRD §5).
//
// ι (this task) introduces the trait and the first refining variant
// TOTSShaper (time-optimal trajectory shaper, PRD §5.2). Future Phase 2
// task δ will add the impulse-shaper refinements ZVShaper / ZVDShaper /
// EIShaper. Whoever lands first wins the trait; δ's architect will see this
// declaration and add only the ZV/ZVD/EI structures that refine it.
//
// Kept empty by design: each variant carries its own per-strategy fields;
// the trait exists only to give the `shaper` param on the `input_shape`
// dispatcher a single nominal type so the SIR-α nominal type-tag dispatches
// correctly. Same marker-trait discipline as `trait Profile { }` (:68) and
// `trait BoundaryCondition { }` (:83).
trait Shaper { }

// ── JointLimit (PRD §5.2) ─────────────────────────────────────────────────────

// JointLimit — per-joint actuator constraint consumed by TOTSShaper (PRD §5.2).
//
// Fields:
//   - joint     : Real   — TODO(joint-type): placeholder for the future
//                          kinematic-completion PRD's Joint type. Same
//                          encoding as `PiecewisePolynomialProfile.mechanism :
//                          Real` (:211, TODO(mechanism-type)) — both reference
//                          kinematic-completion-PRD-owned types that have not
//                          yet landed. When kinematic-completion lands, both
//                          retarget via the same refactor sweep.
//   - max_force : Real   — TODO(force-scalar): placeholder for `Scalar<Force>`
//                          per the uniform-Real-placeholder convention
//                          established in modal_analysis.ri header §1.
//                          Force IS a named dimension but the convention
//                          placeholders all dimensioned scalars uniformly so
//                          the dimensional-tightening sweep retargets them in
//                          a single pass.
//
// No defaults: both fields are caller-supplied. There is no canonical "default
// max force" (the limit is entirely application-specific).
//
// Constraint `max_force > 0` is added in step-34. Explicitly NOT constrained:
// `joint : Real` — placeholder for an entity-handle type; no meaningful scalar
// predicate on a handle.
//
// Refines no trait (JointLimit is a plain data container, not a Shaper
// variant or a BoundaryCondition).
structure def JointLimit {
    param joint : Real
    param max_force : Real

    // max_force is a physical limit — only positive values are meaningful.
    // A "max force" of zero or negative is degenerate (a zero-limit means
    // the joint can exert no force, a negative limit is non-physical).
    // Makes the contract explicit in production code rather than relying
    // solely on test coverage (task #2544 convention, memory id c8452b30).
    // Fires automatically at construction via SIR-α's
    // `check_constraints_against_templates` machinery (task 3540, landed).
    //
    // NOTE — explicitly NOT constrained:
    //   `joint : Real` — placeholder for an entity-handle type; no
    //   meaningful scalar predicate on a handle.
    constraint max_force > 0
}

// ── TOTSShaper (PRD §5.2) ─────────────────────────────────────────────────────

// TOTSShaper — time-optimal trajectory shaping value type (PRD §5.2).
// Solver-input bundle, not a result. Consumed by the future κ-task TOTS
// SQP-loop trampoline that runs the time-optimal shaping algorithm.
//
// Refines the Shaper marker trait declared above — TOTSShaper is one of
// several input-shaper variants; the future Phase 2 task δ adds ZVShaper /
// ZVDShaper / EIShaper. All refine the same `trait Shaper { }`.
//
// Uniform-Real-placeholder encoding convention (modal_analysis.ri header §1):
// All dimensioned scalars are encoded as Real with TODO(...) annotations
// naming the future-tightening target, even when the named dimension IS in
// NAMED_DIMENSIONS. This keeps constraint RHS literals plain (> 0, <= 1)
// and lets the dimensional-tightening sweep retarget every placeholder in a
// single pass.
//
// Fields:
//   - modes              : List<Mode>        — vibration modes resolved via
//                                              the growing-prelude cross-module
//                                              mechanism (std.modal.analysis
//                                              loaded before std.trajectory per
//                                              stdlib_loader.rs:110-116).
//   - actuator_limits    : List<JointLimit>  — per-joint force limits
//                                              (JointLimit declared above).
//   - velocity_limit     : Real              — TODO(velocity-scalar): Scalar<Velocity>
//                                              (Velocity NOT in NAMED_DIMENSIONS,
//                                              so Real is the only option anyway).
//   - acceleration_limit : Real              — TODO(acceleration-scalar): Scalar<Acceleration>
//   - vibration_tolerance: Real              — genuinely dimensionless (residual
//                                              fraction); vibration_tolerance ∈ (0,1]
//                                              per PRD §11 Phase 2 ε spec.
//   - max_iters          : Int = 100         — solver iteration cap per PRD §5.2.
//                                              Default 100 added in step-38.
//   - tol                : Real = 0.000001   — convergence threshold (1e-6).
//                                              Default added in step-38.
//
// Constraints (6 total) added in step-40.
// NOT constrained: modes / actuator_limits (collection invariants deferred
// to the κ-task SQP-loop trampoline, mirroring ModalResult.modes discipline).
structure def TOTSShaper : Shaper {
    param modes : List<Mode>
    param actuator_limits : List<JointLimit>
    param velocity_limit : Real
    param acceleration_limit : Real
    param vibration_tolerance : Real

    // max_iters = 100 per PRD §5.2 explicit default — solver iteration cap.
    // Exists so a pathologically conditioned problem fails loudly (exceeds
    // iteration budget) rather than running forever. Callers with tighter
    // or looser convergence budgets can override.
    param max_iters : Int = 100

    // tol = 0.000001 = 1e-6 per PRD §5.2. Encoded as the decimal literal
    // because Reify's number-literal grammar has no scientific notation (same
    // convention as modal_analysis.ri:356 tol = 0.000000001 = 1e-9 and
    // solver_buckling.ri:79 tol = 0.00000001 = 1e-8). IEEE-754 round-to-
    // nearest of this exact decimal literal is deterministic.
    param tol : Real = 0.000001

    // PRD §5.2 "ctor constraints on numeric design params" + PRD §11 Phase 2 ε
    // spec (vibration_tolerance ∈ (0, 1]).
    //
    // Makes the contract explicit in production code rather than relying solely
    // on test coverage (task #2544 convention, memory id c8452b30). All six
    // fire automatically at construction via SIR-α's
    // `check_constraints_against_templates` machinery (task 3540, landed).
    //
    // velocity_limit, acceleration_limit: must be strictly positive — a zero or
    // negative kinematic limit is non-physical (the robot cannot move at all if
    // the velocity limit is zero, and a negative limit has no physical meaning).
    constraint velocity_limit > 0
    constraint acceleration_limit > 0

    // vibration_tolerance ∈ (0, 1]: residual-vibration fraction. Zero would
    // mean "no vibration allowed ever" (impossible in practice); values > 1
    // would accept more residual vibration than the input itself (degenerate).
    // Two scalar predicates because Reify's constraint grammar admits BinOp
    // predicates but no interval form (PRD §11 Phase 2 ε spec).
    constraint vibration_tolerance > 0
    constraint vibration_tolerance <= 1

    // max_iters: must be strictly positive — a zero iteration count means
    // the solver never runs.
    constraint max_iters > 0

    // tol: convergence threshold must be strictly positive — a zero or
    // negative tolerance would never converge (or converge trivially).
    constraint tol > 0

    // NOTE — explicitly NOT constrained:
    //   `modes : List<Mode>` — collection invariants deferred to the κ-task
    //   SQP-loop trampoline (same discipline as ModalResult.modes).
    //   `actuator_limits : List<JointLimit>` — same collection-invariant
    //   rationale (producer/consumer-enforced at the SQP loop).
}

// ── Impulse shapers (PRD §5.1) ────────────────────────────────────────────────
//
// δ task (3857) adds ZVShaper, ZVDShaper, EIShaper, and CascadedShaper — all
// refining the `trait Shaper { }` marker declared above (:322).
//
// Type decisions (each verified against a landed sibling):
//
//   target_frequency : Frequency → Type::Scalar{dimension: FREQUENCY}.
//     Constraint RHS is the dimensioned literal `0Hz` → Value::Scalar{si_value:
//     0.0, dimension:FREQUENCY}; a bare `0` is Type::Real and dim-incompatible
//     with Frequency (esc-3115 rule, modal_analysis.ri:564-566).
//     Exact precedent: HarmonicForce.frequency:Frequency + constraint frequency
//     > 0Hz (modal_analysis.ri:578-594).
//
//   shapers : List<Shaper> → Type::List(TraitObject("Shaper")).
//     Same encoding as CompositeForce.sources:List<ForcingFunction>
//     (modal_analysis.ri:701).
//
//   damping_ratio default 0.0 (ZVShaper only) → Value::Real(0.0).
//     Matches TOTSShaper.tol:Real = 0.000001 precedent. ZVD/EI have NO default.

// ── ZVShaper (PRD §5.1) ───────────────────────────────────────────────────────

// ZVShaper — Zero-Vibration impulse shaper (PRD §5.1).
//
// The ZV shaper cancels residual vibration at a single target frequency by
// convolving the command with a two-impulse sequence. The default damping_ratio
// of 0.0 matches the PRD §5.1 "undamped" base case; callers with a known
// damping ratio can override.
//
// Fields:
//   - target_frequency : Frequency  — the resonant frequency to suppress.
//                                     Frequency IS in NAMED_DIMENSIONS, so the
//                                     param is typed Frequency (not Real).
//   - damping_ratio    : Real = 0.0 — damping ratio ζ ∈ [0, 1). Default 0.0
//                                     per PRD §5.1 (ZV assumes undamped as base
//                                     case). Decimal literal → Value::Real(0.0)
//                                     (same pattern as TOTSShaper.tol = 0.000001).
//
// Constraint:
//   target_frequency > 0Hz — rejects degenerate zero or negative frequency.
//   The constraint RHS MUST be the dimensioned literal `0Hz` → Value::Scalar
//   {si_value:0.0, dimension:FREQUENCY}; a bare `0` is Type::Real, which is
//   dim-incompatible with Frequency per the esc-3115 rule documented at
//   modal_analysis.ri:564-566.
structure def ZVShaper : Shaper {
    param target_frequency : Frequency
    param damping_ratio : Real = 0.0

    constraint target_frequency > 0Hz
}

