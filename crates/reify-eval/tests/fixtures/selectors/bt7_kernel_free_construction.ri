// Fixture: BT7 — construction is kernel-free (K2 invariant).
// PRD: docs/prds/topology-selector-value-type.md §5 BT7
//
// The `sel` cell is an UNCONSUMED `faces_by_normal(b, dir, tol)` selector.
// Because it is not consumed at a coercion site (no `single()`, `[0]`, etc.),
// the engine leaves it as a kernel-free Value::Selector(Face) and issues ZERO
// kernel query() round-trips during build (K2: lazy, not eager).
//
// Let-bound dir and tol are required because the dispatcher resolves selector
// args via values.get(cell_id); inline vec3()/deg literals compile as
// FunctionCall args which fall through to None in the dispatcher.
//
// Pinning test:
//   crates/reify-eval/tests/selector_boundary_gate.rs::bt7_construction_is_kernel_free

structure def BT7KernelFree {
    let b   = box(10mm, 10mm, 10mm)
    let dir = vec3(0.0, 0.0, 1.0)
    let tol = 1deg
    // Bare, unconsumed selector: stays Value::Selector(Face), never resolved.
    let sel = faces_by_normal(b, dir, tol)
}
