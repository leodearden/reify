// Fixture: BT3 — difference and intersect set semantics.
// PRD: docs/prds/topology-selector-value-type.md §5 BT3
//
// d = difference(faces(b), faces_by_normal(b, up, tol))
//   → all box faces EXCEPT the +Z face: [+X, -X, +Y, -Y, -Z]
//
// i = intersect(faces_by_normal(b, up, tol), faces_by_normal(b, down, tol))
//   → empty (disjoint face sets: +Z face ∩ -Z face = ∅)
//
// Let-bound intermediates (up, down, tol) are required because the dispatcher
// resolves selector args via values.get(cell_id).
//
// Pinning test:
//   crates/reify-eval/tests/selector_boundary_gate.rs::bt3_difference_and_intersect_set_semantics

structure def BT3SetOps {
    let b    = box(10mm, 10mm, 10mm)
    let up   = vec3(0.0, 0.0, 1.0)
    let down = vec3(0.0, 0.0, -1.0)
    let tol  = 1deg
    // difference: all faces minus the +Z face
    let d = difference(faces(b), faces_by_normal(b, up, tol))
    // intersect: +Z face ∩ -Z face = empty (disjoint)
    let i = intersect(faces_by_normal(b, up, tol), faces_by_normal(b, down, tol))
}
