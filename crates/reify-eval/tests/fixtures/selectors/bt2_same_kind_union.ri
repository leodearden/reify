// Fixture: BT2 — same-kind union resolves to set-union (K3 dedup, canonical order).
// PRD: docs/prds/topology-selector-value-type.md §5 BT2
//
// `union(faces_by_normal(b, up, tol), faces_by_normal(b, down, tol))` composes
// two FaceSelectors selecting the +Z and -Z faces respectively. The resolve()
// executor must return [+Z face, -Z face] in canonical first-seen order with
// K3 dedup (no face appears twice).
//
// Let-bound intermediates (up, down, tol) are required because the dispatcher
// resolves selector args via values.get(cell_id).
//
// Pinning test:
//   crates/reify-eval/tests/selector_boundary_gate.rs::bt2_same_kind_union_resolves_to_set_union

structure def BT2SameKindUnion {
    let b    = box(10mm, 10mm, 10mm)
    let up   = vec3(0.0, 0.0, 1.0)
    let down = vec3(0.0, 0.0, -1.0)
    let tol  = 1deg
    let u    = union(faces_by_normal(b, up, tol), faces_by_normal(b, down, tol))
}
