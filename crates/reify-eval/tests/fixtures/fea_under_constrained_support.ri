// FEA diagnostic fixture: under-constrained advisory (PRESENT but unhonored
// support — task 4089 / PRD B10).
//
// A cantilever structure with a PointLoad AND a single PRESENT FixedSupport
// whose target is "tip" — a non-root selector. The synthetic cantilever
// auto-clamp model only honors the "root" face, so this support is
// effectively unhonored and the body is under-constrained relative to
// design intent. Triggers the FeaUnderConstrained warning diagnostic via the
// elastic-static trampoline, this time WITH a DiagnosticLabel referencing
// this FixedSupport's `.ri` construction-site span (unlike fea_no_supports.ri,
// where the empty-supports case has no entity to reference and span stays
// None).
//
// Modelled after examples/fea_cantilever_smoke.ri (same geometry, same
// material) but the support's `target` is "tip" instead of "root".

structure FeaUnderConstrainedSupport {
    param length : Length = 1000mm
    param width  : Length = 100mm
    param height : Length = 100mm

    let material = Steel_AISI_1045()

    // Tip load, same as the smoke test.
    let tip_load = PointLoad(point: "tip", force: 1000.0)

    // Present support, but targeting "tip" instead of the auto-clamped "root".
    let mount = FixedSupport(target: "tip")

    let result = solve_elastic_static(
        material, length, width, height, [tip_load], [mount], ElasticOptions()
    )

    let body = box(length, width, height)
}
