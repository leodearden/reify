// BT2 back-compat fixture (BA order) — task #4826 (F-inherit ζ regression corpus).
//
// Two uncoupled objective-less scopes declared B-then-A, each with a two-sided
// bound.  Mirror of bt2_uncoupled_ab.ri with declaration order reversed.
// No cross-scope reads — the scopes are independent.
//
// `reify eval` output is cell-id-SORTED, so the BA ordering must produce
// BYTE-IDENTICAL stdout to the AB ordering (INV-2 declaration-order independence).
//
// Shared golden: crates/reify-eval/tests/golden/bt2_uncoupled.txt
// Counterpart:   tests/fixtures/backcompat/bt2_uncoupled_ab.ri
// Test:          crates/reify-eval/tests/objective_inheritance_e2e.rs::bt2_uncoupled_declaration_order_independence
structure B {
    param b: Length = auto

    constraint b >= 2mm
    constraint b <= 9mm
}

structure A {
    param a: Length = auto

    constraint a >= 1mm
    constraint a <= 5mm
}
